{
  "name": "vault",
  "version": "1.0.0",
  "description": "Vault - API Key 安全管理器",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:portable": "electron-builder --win portable"
  },
  "author": "Vault",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "sharp": "^0.34.5"
  },
  "build": {
    "appId": "com.vault.app",
    "productName": "Vault",
    "icon": "icon-vault-md-256.png",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "index.html",
      "style.css",
      "app.js",
      "eye-open.jpg",
      "eye-closed.png",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false
    },
    "portable": {
      "artifactName": "Vault.exe"
    }
  }
}
